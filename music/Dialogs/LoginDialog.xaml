<ContentDialog
    x:Class="music.Dialogs.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="登录"
    PrimaryButtonText="登录"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="LoginButton_Click"
    SecondaryButtonClick="CancelButton_Click"
    Style="{StaticResource DefaultContentDialogStyle}"
    Width="400">

    <StackPanel Spacing="16">
        <!-- 登录方式选择 -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button x:Name="PhoneTabButton"
                    Content="手机登录"
                    Click="PhoneTabButton_Click"
                    Padding="16,8"
                    Style="{StaticResource AccentButtonStyle}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE717;" FontSize="14"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button x:Name="QRTabButton"
                    Content="二维码登录"
                    Click="QRTabButton_Click"
                    Padding="16,8">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8F1;" FontSize="14"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!-- 手机登录 -->
        <StackPanel x:Name="PhoneLoginPanel" Spacing="12">
            <TextBox x:Name="PhoneBox" 
                     PlaceholderText="手机号码"
                     InputScope="TelephoneNumber"
                     MaxLength="11"/>
            <PasswordBox x:Name="PasswordBox" 
                         PlaceholderText="密码"
                         MaxLength="50"/>
            <Border x:Name="PhoneErrorBorder"
                    Visibility="Collapsed"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    CornerRadius="4"
                    Padding="12,8">
                <TextBlock x:Name="PhoneErrorText"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- 二维码登录 -->
        <StackPanel x:Name="QRLoginPanel" Spacing="12" Visibility="Collapsed" HorizontalAlignment="Center">
            <Border Width="200" Height="200" 
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    CornerRadius="8">
                <Image x:Name="QRCodeImage" Stretch="Uniform"/>
            </Border>
            <ProgressRing x:Name="QRLoadingRing" IsActive="False" Width="40" Height="40"/>
            <TextBlock x:Name="QRStatusText"
                       Text="请使用网易云音乐APP扫码登录"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button x:Name="RefreshQRButton"
                    Content="刷新二维码"
                    HorizontalAlignment="Center"
                    Click="RefreshQRButton_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>