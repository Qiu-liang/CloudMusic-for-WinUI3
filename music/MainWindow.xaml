<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="music.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Cloud Music">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="NavView"
                    SelectionChanged="NavView_SelectionChanged"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="True">
        <NavigationView.AutoSuggestBox>
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="搜索音乐"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted"/>
        </NavigationView.AutoSuggestBox>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="推荐" Tag="recommend" IsSelected="True">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="关注" Tag="follow">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Contact"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItemHeader Content="我的"/>

            <NavigationViewItem Content="我喜欢的音乐" Tag="liked">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Like"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="最近" Tag="recent">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Clock"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="已下载" Tag="downloaded">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Download"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="音乐云盘" Tag="cloud">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE753;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItemHeader Content="创建的歌单" x:Name="CreatedPlaylistHeader"/>

            <NavigationViewItemHeader Content="收藏的歌单" x:Name="CollectedPlaylistHeader" Visibility="Collapsed"/>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem x:Name="LoginItem" Tag="login" SelectsOnInvoked="False">
                <NavigationViewItem.Icon>
                    <SymbolIcon x:Name="LoginIcon" Symbol="Contact"/>
                </NavigationViewItem.Icon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="LoginStatusText" 
                                       Text="未登录"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       FontSize="13"/>
                            <Border x:Name="VipBadge"
                                    Visibility="Collapsed"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="VIP"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="LoginSubText" 
                                   Text="点击登录"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Button x:Name="LogoutButton"
                            Click="LogoutButton_Click"
                            Padding="4"
                            Background="Transparent"
                            BorderThickness="0"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="退出登录"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7E8;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部返回按钮栏 -->
            <Grid Grid.Row="0" 
                  x:Name="BackBar"
                  Height="48" 
                  Padding="8,0"
                  Visibility="Collapsed"
                  Opacity="0"
                  Translation="0,-48,0">
                <Grid.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="-48"/>
                    </TransitionCollection>
                </Grid.Transitions>
                <Button x:Name="BackButton"
                        Click="BackButton_Click"
                        Padding="8,6"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                        <TextBlock Text="返回" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 内容区域（占满整个空间） -->
            <Frame x:Name="ContentFrame" Grid.Row="1"/>

            <!-- 底部播放控件（覆盖在内容区域上方） -->
            <Grid Grid.Row="1" 
                  x:Name="PlayerBar"
                  Height="72"
                  Padding="8,0"
                  VerticalAlignment="Bottom"
                  Canvas.ZIndex="100">
                <Grid.Background>
                    <AcrylicBrush TintColor="{ThemeResource CardBackgroundFillColorDefault}"
                                  TintOpacity="0.8"
                                  FallbackColor="{ThemeResource CardBackgroundFillColorDefault}"
                                  AlwaysUseFallback="False"/>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- 歌曲信息 -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            Spacing="10" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Left" 
                            Margin="16,0,0,0">
                    <Border x:Name="AlbumCover" 
                            Width="48" Height="48" 
                            CornerRadius="4"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            Tapped="AlbumCover_Tapped"
                            PointerEntered="AlbumCover_PointerEntered"
                            PointerExited="AlbumCover_PointerExited">
                        <Grid>
                            <FontIcon x:Name="AlbumCoverIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D6;" FontSize="22"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="AlbumImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="SongTitle" 
                                   Text="未播放"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   FontSize="14"
                                   MaxWidth="160"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ArtistName" 
                                   Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   MaxWidth="160"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- 播放控制 -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button x:Name="ShuffleButton" 
                                Click="ShuffleButton_Click"
                                Padding="8,6"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="32">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B1;" FontSize="15"/>
                        </Button>
                        <Button x:Name="PrevButton" 
                                Click="PrevButton_Click"
                                Padding="8,6"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="32">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" FontSize="15"/>
                        </Button>
                        <Button x:Name="PlayPauseButton" 
                                Style="{StaticResource AccentButtonStyle}"
                                Click="PlayPauseButton_Click"
                                Width="36" Height="36"
                                Padding="0">
                            <FontIcon x:Name="PlayPauseIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="18"/>
                        </Button>
                        <Button x:Name="NextButton" 
                                Click="NextButton_Click"
                                Padding="8,6"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="32">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" FontSize="15"/>
                        </Button>
                        <Button x:Name="RepeatButton" 
                                Click="RepeatButton_Click"
                                Padding="8,6"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="32">
                            <FontIcon x:Name="RepeatIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8EE;" FontSize="15"/>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock x:Name="CurrentTime" 
                                   Grid.Column="0"
                                   Text="00:00" 
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontSize="11"
                                   Width="36"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Slider x:Name="ProgressSlider" 
                                Grid.Column="1"
                                MinWidth="150"
                                Height="24"
                                Minimum="0" Maximum="100" 
                                ValueChanged="ProgressSlider_ValueChanged"
                                PointerEntered="ProgressSlider_PointerEntered"
                                PointerExited="ProgressSlider_PointerExited"
                                IsThumbToolTipEnabled="False"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalTime" 
                                   Grid.Column="2"
                                   Text="00:00" 
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontSize="11"
                                   Width="36"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </Grid>

                <!-- 音量控制 -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Spacing="8" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Right" 
                            Margin="0,0,8,0">
                    <!-- 音质选择 -->
                    <DropDownButton x:Name="QualityButton"
                                    Padding="8,4"
                                    VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE7F4;" FontSize="14"/>
                            <TextBlock x:Name="QualityText" 
                                       Text="标准" 
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="TopEdgeAlignedRight">
                                <MenuFlyoutItem Text="标准" Click="Quality_Click" Tag="standard"/>
                                <MenuFlyoutItem Text="较高" Click="Quality_Click" Tag="higher"/>
                                <MenuFlyoutItem Text="极高" Click="Quality_Click" Tag="exhigh"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="无损 (VIP)" Click="Quality_Click" Tag="lossless"/>
                                <MenuFlyoutItem Text="Hi-Res (VIP)" Click="Quality_Click" Tag="hires"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="高清臻音 (VIP)" Click="Quality_Click" Tag="jyeffect"/>
                                <MenuFlyoutItem Text="沉浸环绕声" Click="Quality_Click" Tag="sky"/>
                                <MenuFlyoutItem Text="杜比全景声" Click="Quality_Click" Tag="dolby"/>
                                <MenuFlyoutItem Text="超清母带 (VIP)" Click="Quality_Click" Tag="jymaster"/>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Button x:Name="VolumeButton" 
                            Click="VolumeButton_Click"
                            Padding="8,4"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <FontIcon x:Name="VolumeIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE767;" FontSize="14"/>
                    </Button>
                    <Slider x:Name="VolumeSlider" 
                            Width="90" 
                            VerticalAlignment="Center"
                            Minimum="0" Maximum="100" 
                            Value="100"
                            ValueChanged="VolumeSlider_ValueChanged"
                            IsThumbToolTipEnabled="False"/>
                </StackPanel>
            </Grid>
        </Grid>
    </NavigationView>
</Window>