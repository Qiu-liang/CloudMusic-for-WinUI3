<Page
    x:Class="music.Pages.AllPlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:TrackCountConverter x:Key="TrackCountConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="推荐歌单"
                   FontSize="34"
                   FontWeight="Bold"
                   Margin="24,16,24,8"/>

        <!-- 加载中 -->
        <Grid x:ConnectionId='2' Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 错误状态 -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:ConnectionId='11' x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:ConnectionId='12' Content="重试"                          />
            </StackPanel>
        </Grid>

        <!-- 歌单列表 -->
        <GridView x:ConnectionId='4' Grid.Row="1"
                  x:Name="PlaylistsGridView"
                  Visibility="Collapsed"
                  Margin="24,0,24,24"
                  Padding="0,0,0,16"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                                                         >
            <GridView.ItemTemplate>
                <DataTemplate                                >
                    <Border x:ConnectionId='6' Width="180"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="0,0,0,12"
                            Margin="0,0,8,8">
                        <StackPanel Spacing="8">
                            <Border Height="180" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Image x:ConnectionId='9'                         
                                           Stretch="UniformToFill"/>
                                    <Border Background="#40000000"
                                            CornerRadius="8,8,0,0"
                                            VerticalAlignment="Bottom"
                                            Padding="8,4"
                                            MinHeight="28">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE768;" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock x:ConnectionId='10'                                   
                                                       FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Padding="8,0,8,0" Spacing="2">
                                <TextBlock x:ConnectionId='7'                     
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='8'                                                                           
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MaxLines="1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>

