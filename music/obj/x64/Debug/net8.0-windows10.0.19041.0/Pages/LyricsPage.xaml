<Page
    x:Class="music.Pages.LyricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- 主布局 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 顶部栏 -->
            <RowDefinition Height="*"/>     <!-- 内容区域 -->
        </Grid.RowDefinitions>

        <!-- ==================== 顶部歌曲信息栏 ==================== -->
        <Grid Grid.Row="0" Height="56" Padding="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" 
                        VerticalAlignment="Center"
                        Spacing="2">
                <TextBlock x:ConnectionId='6' x:Name="SongTitleText"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:ConnectionId='7' x:Name="ArtistText"
                           Text=""
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Button x:ConnectionId='5' Grid.Column="1"
                    x:Name="CloseButton"
                                             
                    Padding="8"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE711;" FontSize="20"/>
            </Button>
        </Grid>

        <!-- ==================== 歌词内容区域（居中布局） ==================== -->
        <Grid Grid.Row="1">
            <!-- 居中容器，最大宽度限制 -->
            <Grid MaxWidth="900" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Margin="40,0,40,40">
                <Grid.ColumnDefinitions>
                    <!-- 封面列：固定宽度 -->
                    <ColumnDefinition Width="280"/>
                    <!-- 间距 -->
                    <ColumnDefinition Width="110"/>
                    <!-- 歌词列：自适应 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== 封面区域 ==================== -->
                <Border Grid.Column="0"
                        Width="280" Height="280"
                        CornerRadius="12"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ControlFillColorDefaultBrush}">
                    <Image x:ConnectionId='4' x:Name="AlbumImage" Stretch="UniformToFill"/>
                </Border>

                <!-- ==================== 歌词区域 ==================== -->
                <ScrollViewer x:ConnectionId='2' Grid.Column="2"
                              x:Name="LyricsScroller"
                              VerticalAlignment="Stretch"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:ConnectionId='3' x:Name="LyricsPanel"
                                Spacing="14"
                                VerticalAlignment="Center"
                                Padding="0,150,0,150">
                        <TextBlock Text="暂无歌词"
                                   FontSize="16"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>

