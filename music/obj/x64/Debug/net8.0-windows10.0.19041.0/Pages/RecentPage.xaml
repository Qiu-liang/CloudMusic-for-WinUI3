<Page
    x:Class="music.Pages.RecentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE81C;" FontSize="20" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="最近播放"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <TextBlock x:ConnectionId='17' x:Name="CountText"
                           Text=""
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Button x:ConnectionId='16' Grid.Column="1"
                    x:Name="RefreshButton"
                                               
                    VerticalAlignment="Center"
                    Padding="12,8"
                    Background="Transparent"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    <TextBlock Text="刷新" FontSize="14"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 加载中 -->
        <Grid x:ConnectionId='2' Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 空状态 -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE81C;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="还没有播放记录"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="快去听首歌吧"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 错误状态 -->
        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:ConnectionId='14' x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:ConnectionId='15' Content="重试"                            />
            </StackPanel>
        </Grid>

        <!-- 歌曲列表 -->
        <ListView x:ConnectionId='5' Grid.Row="1"
                  x:Name="SongsListView"
                  Visibility="Collapsed"
                  IsItemClickEnabled="True"
                                                     
                  SelectionMode="None"
                  Padding="0,0,0,8">
            <ListView.Header>
                <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,16,0"/>
                    <TextBlock Grid.Column="2" Text="播放时间" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="平台" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="时长" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate                                  >
                    <Grid x:ConnectionId='7' Height="56" Padding="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE8D6;" FontSize="18"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,16,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='12'                     
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border x:ConnectionId='13'                                    
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="VIP"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:ConnectionId='11'                       
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock x:ConnectionId='8' Grid.Column="2"
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:ConnectionId='9' Grid.Column="3"
                                                               
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:ConnectionId='10' Grid.Column="4"
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

