<Page
    x:Class="music.Pages.FollowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToFollowTextConverter x:Key="BoolToFollowTextConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="关注"
                       FontSize="34"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button x:ConnectionId='16' Grid.Column="1"
                    x:Name="RefreshButton"
                                               
                    VerticalAlignment="Center"
                    Padding="12,8"
                    Background="Transparent"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    <TextBlock Text="刷新" FontSize="14"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 选项卡 -->
        <NavigationView x:ConnectionId='2' Grid.Row="1"
                        x:Name="FollowNavView"
                        PaneDisplayMode="Top"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                                                                         >
            <NavigationView.MenuItems>
                <NavigationViewItem Content="关注" Tag="follows" IsSelected="True"/>
                <NavigationViewItem Content="粉丝" Tag="followeds"/>
            </NavigationView.MenuItems>
        </NavigationView>

        <!-- 加载中 -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="LoadingPanel" Margin="0,80,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..."
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 错误状态 -->
        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed" Margin="0,80,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE783;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:ConnectionId='14' x:Name="ErrorText"
                           Text="加载失败"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:ConnectionId='15' Content="重试"                             Padding="16,8"/>
            </StackPanel>
        </Grid>

        <!-- 空状态 -->
        <Grid x:ConnectionId='5' Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed" Margin="0,80,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE77B;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:ConnectionId='13' x:Name="EmptyText"
                           Text="暂无关注"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 用户列表 -->
        <ListView x:ConnectionId='6' Grid.Row="1"
                  x:Name="UsersListView"
                  Visibility="Collapsed"
                  Margin="0,56,0,0"
                  SelectionMode="None"
                  Padding="24,8">
            <ListView.ItemTemplate>
                <DataTemplate                                  >
                    <Grid x:ConnectionId='8' Height="72" Padding="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="48" Height="48"
                                CornerRadius="24"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <Image x:ConnectionId='12'                            
                                   Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,16,0">
                            <TextBlock x:ConnectionId='10'                         
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:ConnectionId='11'                          
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button x:ConnectionId='9' Grid.Column="2"
                                                     
                                                          
                                Padding="16,6"
                                VerticalAlignment="Center"
                                                                                                                 />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

