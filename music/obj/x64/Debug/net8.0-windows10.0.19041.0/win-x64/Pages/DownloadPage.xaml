<Page
    x:Class="music.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Grid Margin="24,8,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:ConnectionId='11' Grid.Column="0"
                       x:Name="CountText"
                       Text="共 0 首"
                       Style="{StaticResource BodyTextBlockStyle}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Button x:ConnectionId='12' Grid.Column="1"
                    x:Name="DownloadButton"
                                                
                    Padding="12,6"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                    <TextBlock Text="下载歌曲"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 加载中 -->
        <Grid x:ConnectionId='2' Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 空状态 -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE896;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="还没有下载的歌曲"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="点击上方按钮下载歌曲"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 歌曲列表 -->
        <ListView x:ConnectionId='4' Grid.Row="1"
                  x:Name="SongsListView"
                  Visibility="Collapsed"
                  IsItemClickEnabled="True"
                                                     
                  SelectionMode="None"
                  Padding="0,0,0,8">
            <ListView.Header>
                <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,16,0"/>
                    <TextBlock Grid.Column="2" Text="大小" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="" FontSize="12"
                               VerticalAlignment="Center"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate                                      >
                    <Grid x:ConnectionId='6' Height="56" Padding="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE8D6;" FontSize="18"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,16,0">
                            <TextBlock x:ConnectionId='9'                     
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:ConnectionId='10'                       
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock x:ConnectionId='7' Grid.Column="2"
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Button x:ConnectionId='8' Grid.Column="3"
                                                 
                                                          
                                Padding="4"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="删除">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

