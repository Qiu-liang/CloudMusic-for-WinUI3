<Page
    x:Class="music.Pages.CloudPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE753;" FontSize="20" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="音乐云盘"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <TextBlock x:ConnectionId='18' x:Name="SongsCountText"
                           Text=""
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:ConnectionId='16' x:Name="UploadButton" 
                                                  
                        Padding="12,6"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE898;" FontSize="14"/>
                        <TextBlock Text="上传音乐"/>
                    </StackPanel>
                </Button>
                <Button x:ConnectionId='17' x:Name="RefreshButton" 
                                                   
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:ConnectionId='2' Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..." 
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE753;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="云盘还没有音乐"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="点击上方按钮上传本地音乐"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48" 
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:ConnectionId='14' x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:ConnectionId='15' Content="重试"                            />
            </StackPanel>
        </Grid>

        <ListView x:ConnectionId='5' Grid.Row="1"
                  x:Name="SongsListView"
                  Visibility="Collapsed"
                  IsItemClickEnabled="True"
                                                     
                  SelectionMode="None"
                  Padding="0,0,0,8">
            <ListView.Header>
                <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="12,0,16,0"/>
                    <TextBlock Grid.Column="2" Text="大小" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="上传时间" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="时长" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="" FontSize="12" 
                               VerticalAlignment="Center"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate                                 >
                    <Grid x:ConnectionId='7' Height="56" Padding="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" 
                                Width="40" Height="40" 
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE8D6;" FontSize="18" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" 
                                    VerticalAlignment="Center" 
                                    Margin="12,0,16,0">
                            <TextBlock x:ConnectionId='12'                          
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:ConnectionId='13'                        
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock x:ConnectionId='8' Grid.Column="2" 
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:ConnectionId='9' Grid.Column="3" 
                                                                   
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:ConnectionId='10' Grid.Column="4" 
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Button x:ConnectionId='11' Grid.Column="5"
                                                     
                                                          
                                Padding="4"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="删除">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

