<Page
    x:Class="music.Pages.LikedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="24,16,24,8">
            <FontIcon Glyph="&#xE8D6;" FontSize="20" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
            <TextBlock Text="我喜欢的音乐"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock x:ConnectionId='18' x:Name="SongsCountText"
                       Text=""
                       Style="{StaticResource BodyTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Grid x:ConnectionId='2' Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..." 
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE8D6;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="还没有喜欢的音乐"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="在播放页面点击心形图标添加"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48" 
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:ConnectionId='16' x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:ConnectionId='17' Content="重试"                          />
            </StackPanel>
        </Grid>

        <ListView x:ConnectionId='5' Grid.Row="1"
                  x:Name="SongsListView"
                  Visibility="Collapsed"
                  IsItemClickEnabled="True"
                                                     
                  SelectionMode="None"
                  Padding="0,0,0,8">
            <ListView.Header>
                <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="12,0,16,0"/>
                    <TextBlock Grid.Column="2" Text="专辑" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="时长" FontSize="12" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate                            >
                    <Grid x:ConnectionId='7' Height="56" Padding="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" 
                                Width="40" Height="40" 
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <Grid>
                                <FontIcon Glyph="&#xE8D6;" FontSize="18" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:ConnectionId='15'                            
                                       Stretch="UniformToFill" 
                                                                            />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,16,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='11'                     
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border x:ConnectionId='12' x:Name="VipBadge"
                                                                           
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="VIP"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                                <Border x:ConnectionId='13' x:Name="PaidBadge"
                                                                            
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock x:ConnectionId='14'                        
                                               FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:ConnectionId='10'                            
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock x:ConnectionId='8' Grid.Column="2" 
                                                            
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock x:ConnectionId='9' Grid.Column="3" 
                                                                    
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

