<Page
    x:Class="music.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:ConnectionId='2' x:Name="TitleText"
                   Text="搜索"
                   FontSize="34"
                   FontWeight="Bold"
                   Margin="24,16,24,8"/>

        <!-- 空状态 -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="EmptyState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <FontIcon Glyph="&#xE721;"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="搜索音乐"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="使用顶部搜索框搜索您喜欢的音乐"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 加载中 -->
        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="LoadingPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="搜索中..."
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 搜索结果 -->
        <Grid x:ConnectionId='5' Grid.Row="1" x:Name="ResultsPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:ConnectionId='6' x:Name="ResultsCountText"
                       Margin="24,8,24,8"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <ListView x:ConnectionId='7' Grid.Row="1"
                      x:Name="SongsListView"
                      IsItemClickEnabled="True"
                                                         
                      SelectionMode="None"
                      Padding="0,0,0,8">
                <ListView.Header>
                    <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,16,0"/>
                        <TextBlock Grid.Column="2" Text="专辑" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="时长" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate                            >
                        <Grid x:ConnectionId='9' Height="56" Padding="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- 封面 -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <FontIcon Glyph="&#xE8D6;" FontSize="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image x:ConnectionId='17'                           
                                           Stretch="UniformToFill"
                                                                                />
                                </Grid>
                            </Border>

                            <!-- 歌曲信息 -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="12,0,16,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock x:ConnectionId='13'                     
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border x:ConnectionId='14' x:Name="VipBadge"
                                                                               
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="VIP"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <Border x:ConnectionId='15' x:Name="PaidBadge"
                                                                                
                                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock x:ConnectionId='16'                        
                                                   FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:ConnectionId='12'                            
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- 专辑 -->
                            <TextBlock x:ConnectionId='10' Grid.Column="2"
                                                                
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- 时长 -->
                            <TextBlock x:ConnectionId='11' Grid.Column="3"
                                                                        
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

