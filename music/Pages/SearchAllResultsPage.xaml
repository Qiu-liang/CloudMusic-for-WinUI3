<Page
    x:Class="music.Pages.SearchAllResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:TrackCountConverter x:Key="TrackCountConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Text="搜索结果"
                   FontSize="34"
                   FontWeight="Bold"
                   Margin="24,16,24,8"/>

        <!-- 加载中 -->
        <Grid Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 错误状态 -->
        <Grid Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="重试" Click="RetryButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- 结果列表 -->
        <GridView Grid.Row="1"
                  x:Name="ResultsGridView"
                  Visibility="Collapsed"
                  Margin="24,0,24,24"
                  Padding="0,0,0,16"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="ResultsGridView_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:PlaylistItem">
                    <Border Width="180"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="0,0,0,12"
                            Margin="0,0,8,8">
                        <StackPanel Spacing="8">
                            <Border Height="180" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Image Source="{x:Bind PicUrl}"
                                           Stretch="UniformToFill"/>
                                    <Border Background="#40000000"
                                            CornerRadius="8,8,0,0"
                                            VerticalAlignment="Bottom"
                                            Padding="8,4"
                                            MinHeight="28">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE768;" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind PlayCountFormatted}"
                                                       FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Padding="8,0,8,0" Spacing="2">
                                <TextBlock Text="{x:Bind Name}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind TrackCount, Converter={StaticResource TrackCountConverter}}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MaxLines="1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
