<Page
    x:Class="music.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="设置"
                   FontSize="34"
                   FontWeight="Bold"
                   Margin="24,16,24,8"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Margin="24,0,24,24" HorizontalAlignment="Stretch">
                
                <!-- 外观设置 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="主题模式" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="选择应用的外观主题" FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" 
                                      x:Name="ThemeComboBox"
                                      SelectionChanged="ThemeComboBox_SelectionChanged"
                                      MinWidth="120"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="跟随系统"/>
                                <ComboBoxItem Content="浅色"/>
                                <ComboBoxItem Content="深色"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 网络设置 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="网络" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="API服务器地址" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="NeteaseCloudMusicApi服务地址" FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" 
                                         x:Name="ServerAddressBox"
                                         PlaceholderText="http://localhost:3000"/>
                                <Button Grid.Column="1" 
                                        x:Name="SaveServerButton"
                                        Click="SaveServerButton_Click"
                                        VerticalAlignment="Bottom"
                                        Padding="16,8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                        <TextBlock Text="保存"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="ServerStatusText"
                                       Text=""
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="连接测试" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="测试服务器是否可访问" FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" 
                                    x:Name="TestConnectionButton"
                                    Click="TestConnectionButton_Click"
                                    Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                    <TextBlock Text="测试"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 播放设置 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="播放" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="音质选择" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="选择播放时的音频质量" FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" 
                                      x:Name="QualityComboBox"
                                      MinWidth="160"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="标准" Tag="standard"/>
                                <ComboBoxItem Content="较高" Tag="higher"/>
                                <ComboBoxItem Content="极高" Tag="exhigh"/>
                                <ComboBoxItem Content="无损 (VIP)" Tag="lossless"/>
                                <ComboBoxItem Content="Hi-Res (VIP)" Tag="hires"/>
                                <ComboBoxItem Content="高清臻音 (VIP)" Tag="jyeffect"/>
                                <ComboBoxItem Content="沉浸环绕声" Tag="sky"/>
                                <ComboBoxItem Content="杜比全景声" Tag="dolby"/>
                                <ComboBoxItem Content="超清母带 (VIP)" Tag="jymaster"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 关于 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="关于" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="应用名称" FontSize="14" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Cloud Music" FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="版本" FontSize="14" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0.1.0" FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="框架" FontSize="14" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="WinUI 3 / .NET 8" FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="API" FontSize="14" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="NeteaseCloudMusicApi" FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>