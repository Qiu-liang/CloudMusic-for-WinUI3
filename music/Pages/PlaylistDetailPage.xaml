<Page
    x:Class="music.Pages.PlaylistDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:music.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8B8;" FontSize="20" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock x:Name="TitleText"
                           Text="歌单详情"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="SongsCountText"
                           Text=""
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Button Grid.Column="2"
                    x:Name="PlayAllButton"
                    Click="PlayAllButton_Click"
                    Padding="12,6"
                    Style="{StaticResource AccentButtonStyle}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE768;" FontSize="14"/>
                    <TextBlock Text="播放全部"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" x:Name="LoadingPanel">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="加载中..." 
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE783;" FontSize="48" 
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText"
                           Text="加载失败"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="重试" Click="RetryButton_Click"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" x:Name="ContentPanel" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!-- 介绍信息区域 -->
                <Grid x:Name="InfoSection" Margin="24,16,24,16" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 封面 -->
                    <Border Grid.Column="0"
                            Width="200" Height="200"
                            CornerRadius="12"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            Margin="0,0,20,0">
                        <Grid>
                            <FontIcon Glyph="&#xE8D6;" FontSize="64"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Image x:Name="CoverImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- 详细信息 -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="12">

                        <!-- 标题 -->
                        <TextBlock x:Name="InfoTitle"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- 创建者信息 -->
                        <StackPanel x:Name="CreatorPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                            <Border Width="28" Height="28" CornerRadius="14">
                                <Grid>
                                    <FontIcon Glyph="&#xE77B;" FontSize="14"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="CreatorAvatar">
                                        <Ellipse.Fill>
                                            <ImageBrush x:Name="CreatorAvatarBrush" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="CreatorNameText"
                                       FontSize="14"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 标签 -->
                        <StackPanel x:Name="TagsPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                            <FontIcon Glyph="&#xE8EC;" FontSize="14" VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TagsText"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 统计信息 -->
                        <StackPanel x:Name="StatsPanel" Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE768;" FontSize="14" VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="PlayCountText"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel x:Name="SubscribedPanel" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                                <FontIcon Glyph="&#xE734;" FontSize="14" VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="SubscribedCountText"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 描述 -->
                        <TextBlock x:Name="DescriptionText"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="Collapsed"/>

                        <!-- 公司信息（专辑） -->
                        <StackPanel x:Name="CompanyPanel" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                            <FontIcon Glyph="&#xE8F1;" FontSize="14" VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="CompanyText"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- 歌曲列表 -->
                <ListView x:Name="SongsListView"
                          IsItemClickEnabled="True"
                          ItemClick="SongsListView_ItemClick"
                          SelectionMode="None"
                          Padding="0,0,0,8">
                    <ListView.Header>
                        <Grid Height="36" Padding="24,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="歌曲" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       VerticalAlignment="Center" Margin="12,0,16,0"/>
                            <TextBlock Grid.Column="2" Text="专辑" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="时长" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SongItem">
                            <Grid Height="56" Padding="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Width="40" Height="40" 
                                        CornerRadius="4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8D6;" FontSize="18" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{x:Bind CoverUrl}" 
                                               Stretch="UniformToFill" 
                                               Visibility="{x:Bind CoverVisibility}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="12,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Visibility="{x:Bind VipVisibility}"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="VIP"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <Border Visibility="{x:Bind PaidVisibility}"
                                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind FeeText}"
                                                       FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind ArtistNames}"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" 
                                           Text="{x:Bind AlbumName}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3" 
                                           Text="{x:Bind DurationFormatted}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
